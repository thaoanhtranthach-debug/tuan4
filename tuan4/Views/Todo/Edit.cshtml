@model tuan4.Models.Todo
@{
    ViewData["Title"] = "Sửa công việc";
}

<h2>Sửa công việc</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label>Mã công việc</label>
        <input asp-for="Id" class="form-control" readonly />
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Tên công việc</label>
        <input asp-for="TaskName" class="form-control" />
        <span asp-validation-for="TaskName" class="text-danger"></span>
    </div>

    <div class="form-check">
        <input asp-for="IsCompleted" class="form-check-input" />
        <label class="form-check-label">Đã hoàn thành</label>
    </div>

    <button type="submit" class="btn btn-primary">Sửa</button>
    <a asp-action="Index" class="btn btn-link">Quay lại</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
