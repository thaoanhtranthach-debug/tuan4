@model tuan4.Models.Todo
@{
    ViewData["Title"] = "Xóa công việc";
}

<h2>Xóa công việc</h2>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Mã công việc</label>
        <div class="form-control-plaintext">@Model.Id</div>
    </div>

    <div class="form-group">
        <label>Tên công việc</label>
        <div class="form-control-plaintext">@Model.TaskName</div>
    </div>

    <div class="form-group">
        <label>Trạng thái</label>
        <div class="form-control-plaintext">@(Model.IsCompleted ? "Đã hoàn thành" : "Chưa hoàn thành")</div>
    </div>

    <p>Bạn có chắc muốn xóa công việc này?</p>

    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-link">Hủy</a>
</form>
